---
import "../styles/global.css";
import type { Locale } from "../lib/i18n";
import { getTranslation } from "../lib/translations";
import { FeedbackDetailView } from "./feedback-detail-view";
import { Footer } from "./footer";
import PageHead from "./page-head.astro";
import { SiteHeader } from "./site-header";

interface Props {
  feedbackId: string;
  locale: Locale;
}

const { feedbackId, locale } = Astro.props;
const t = getTranslation(locale);
const meta = t.meta.feedback;
const path = `/feedback/${feedbackId}`;
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <PageHead locale={locale} path={path} title={meta.title} description={meta.description} />
  </head>
  <body class="font-sans antialiased bg-background text-foreground">
    <a class="skip-link" href="#main">{t.common.skipToContent}</a>
    <SiteHeader
      copy={t.header}
      currentPath="/feedback"
      languageLabel={t.footer.language}
      locale={locale}
      client:load
    />

    <main id="main">
      <FeedbackDetailView
        copy={t.feedback}
        feedbackId={feedbackId}
        locale={locale}
        client:load
      />
    </main>

    <Footer copy={t.footer} locale={locale} showProductLinks={false} client:visible={{ rootMargin: "-25% 0px" }} />
  </body>
</html>
